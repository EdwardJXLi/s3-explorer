# Server
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
SESSION_SECRET=replace-with-a-long-random-string

# UI branding
APP_NAME=S3 Explorer
# APP_ICON_URL=https://example.com/icon.png
APP_DEFAULT_THEME=light

# S3-compatible storage. Works with MinIO, Cloudflare R2, AWS S3, Backblaze B2, etc.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true

# Recommended when the storage account cannot list every bucket.
STORAGE_BUCKETS=my-bucket,archive
STORAGE_DEFAULT_BUCKET=my-bucket
STORAGE_ALLOW_BUCKET_LIST=false
STORAGE_MAX_UPLOAD_BYTES=536870912
# Set STORAGE_MAX_UPLOAD_BYTES=0 to disable the app-level upload limit.

# Default download flow returns direct presigned URLs. Enable this to allow /api/download proxying.
ENABLE_PROXY_DOWNLOADS=false
DEFAULT_PRESIGN_SECONDS=300
MAX_PRESIGN_SECONDS=604800

# Authentication: simple, oidc, or none.
AUTH_MODE=simple
SIMPLE_AUTH_USERNAME=admin
SIMPLE_AUTH_PASSWORD=change-me
SIMPLE_AUTH_EMAIL=admin@example.com
SIMPLE_AUTH_ADMIN=true

# Admin mapping. Everyone else is a viewer by default.
ADMIN_EMAILS=admin@example.com

# OIDC / OAuth2 with PKCE. Example values; provider names and claims are configurable.
# AUTH_MODE=oidc
# OIDC_ISSUER_URL=https://issuer.example.com
# OIDC_CLIENT_ID=s3-explorer
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://files.example.com/api/auth/oidc/callback
# OIDC_SCOPES=openid email profile
# OIDC_EMAIL_CLAIM=email
# OIDC_NAME_CLAIM=name
# OIDC_ROLE_CLAIM=roles
# OIDC_ADMIN_ROLE_VALUES=admin,storage-admin
# OIDC_EXTRA_AUTHORIZE_PARAMS=
